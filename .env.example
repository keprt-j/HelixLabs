# HelixLabs environment template

# Backend
HELIXLABS_ENV=development
HELIXLABS_STORAGE_MODE=json
HELIXLABS_DB_URL=sqlite:///./helixlabs.db
HELIXLABS_ENABLE_LIVE_SEARCH=true
HELIXLABS_ENABLE_FALLBACK_DATA=true

# Optional literature APIs
SEMANTIC_SCHOLAR_API_KEY=
CROSSREF_MAILTO=
NCBI_API_KEY=
OPENAI_API_KEY=

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
